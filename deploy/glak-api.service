[Unit]
Description=Genesis Learning Academy API (contact + enrollment forms)
After=network.target

[Service]
Type=simple
User=glak
Group=glak
WorkingDirectory=/home/glak/htdocs/genesislearningacademyofkennesaw.com
Environment=NODE_ENV=production
Environment=PORT=3002
EnvironmentFile=-/etc/glak-api.env
ExecStart=/home/glak/bin/node server.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
